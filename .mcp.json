{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp",
        "--cdp-endpoint", "http://127.0.0.1:9222",
        "--caps", "vision"
      ]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "chrome-devtools-mcp",
        "--browserUrl", "http://127.0.0.1:9222"
      ]
    }
  }
}
